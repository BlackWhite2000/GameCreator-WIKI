{
  "eslint.experimental.useFlatConfig": true,
  "common-intellisense.ui": [],
  "markdownlint.config": {
    "default": true,
    "MD033": false
  },
  "cSpell.words": [
    "callout",
    "heroicons",
    "nuxt"
  ],
  "markdown.copyFiles.destination": {
    "/content/zh_hans/commands/event/*.md": "/public/image/zh_hans/commands/event/${documentBaseName}/${fileName}",
    "/content/zh_hans/commands/gameprogress/*.md": "/public/image/zh_hans/commands/gameprogress/${documentBaseName}/${fileName}",
    "/content/zh_hans/commands/logic/*.md": "/public/image/zh_hans/commands/logic/${documentBaseName}/${fileName}",
    "/content/zh_hans/commands/news/*.md": "/public/image/zh_hans/commands/news/${documentBaseName}/${fileName}",
    "/content/zh_hans/commands/images/*.md": "/public/image/zh_hans/commands/images/${documentBaseName}/${fileName}",
    "/content/zh_hans/commands/effect/*.md": "/public/image/zh_hans/commands/effect/${documentBaseName}/${fileName}",
    "/content/zh_hans/commands/interface/*.md": "/public/image/zh_hans/commands/interface/${documentBaseName}/${fileName}",
    "/content/zh_hans/commands/audio/*.md": "/public/image/zh_hans/commands/audio/${documentBaseName}/${fileName}",
    "/content/zh_hans/commands/system/*.md": "/public/image/zh_hans/commands/system/${documentBaseName}/${fileName}",
    "/content/zh_hans/commands/plugincommand/*.md": "/public/image/zh_hans/commands/plugincommand/${documentBaseName}/${fileName}",
  },
}