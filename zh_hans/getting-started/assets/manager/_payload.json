20},"刷新",[1722],{"type":922,"value":1720},{"type":917,"tag":918,"props":1724,"children":1725},{},[1726],{"type":922,"value":1727},"鼠标点击空白区域时，使用右键打开菜单，即可看到「刷新」。",{"type":917,"tag":918,"props":1729,"children":1730},{},[1731],{"type":922,"value":1732},"资源管理使用了缓存文件设计（asset/assetList.json），当通过非GC内资源管理器的变更资源时，",{"type":917,"tag":918,"props":1734,"children":1735},{},[1736],{"type":922,"value":1737},"由于系统会自动刷新，所以该功能通常情况下无需使用。",{"type":917,"tag":938,"props":1739,"children":1741},{"id":1740},"复制当前全文件路径",[1742],{"type":922,"value":1740},{"type":917,"tag":918,"props":1744,"children":1745},{},[1746],{"type":922,"value":1747},"鼠标点击空白区域时，使用右键打开菜单，即可看到「复制当前全文件路径」。",{"type":917,"tag":918,"props":1749,"children":1750},{},[1751],{"type":922,"value":1752},"将复制结果储存到剪切板中，通常编写脚本时可能用到此功能，方便将指定的目录下的所有文件列举出来。",{"type":917,"tag":918,"props":1754,"children":1755},{},[1756],{"type":922,"value":1757},"比如WEB端是没有API获取指定文件夹下的所有文件的，可通过此方法直接写到代码上。",{"type":917,"tag":938,"props":1759,"children":1761},{"id":1760},"选择资源",[1762],{"type":922,"value":1760},{"type":917,"tag":918,"props":1764,"children":1765},{},[1766],{"type":922,"value":1767},"选择一张或多张（部分选择资源时是支持多选的）图片点击确定即可",{"type":917,"tag":918,"props":1769,"children":1770},{},[1771],{"type":917,"tag":947,"props":1772,"children":1774},{"alt":949,"src":1773},"/image/zh_hans/getting-started/6.assets/2.manager/image-8.png",[],{"type":917,"tag":918,"props":1776,"children":1777},{},[1778],{"type":922,"value":1779},"如果是音频的话可以在选择时候确定音量和音调大小，也可以试听",{"type":917,"tag":918,"props":1781,"children":1782},{},[1783],{"type":917,"tag":947,"props":1784,"children":1786},{"alt":949,"src":1785},"/image/zh_hans/getting-started/6.assets/2.manager/image-9.png",[],{"title":911,"searchDepth":1788,"depth":1788,"links":1789},2,[1790,1791,1792,1793,1794,1795,1796,1797,1798,1799,1800,1801,1802,1803,1804,1805,1806],{"id":940,"depth":1788,"text":940},{"id":1060,"depth":1788,"text":1060},{"id":1184,"depth":1788,"text":1184},{"id":1260,"depth":1788,"text":1260},{"id":1275,"depth":1788,"