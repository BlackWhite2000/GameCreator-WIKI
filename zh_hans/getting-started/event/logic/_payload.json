:713,"description":912,"body":913,"_type":953,"_id":954,"_source":955,"_file":956,"_stem":957,"_extension":958},"event",false,"","可以控制游戏的执行逻辑、执行顺序，如触发不用的游戏结局",{"type":914,"children":915,"toc":949},"root",[916,924,929,938,944],{"type":917,"tag":918,"props":919,"children":920},"element","p",{},[921],{"type":922,"value":923},"text","使用逻辑控制的相关指令可以控制指令执行的流程，例如有些指令可能需要执行几十次，甚至几百次，",{"type":917,"tag":918,"props":925,"children":926},{},[927],{"type":922,"value":928},"此时就应当使用逻辑控制的相关指令来实现，而不是使用几十个甚至几百个相似的指令来达成目的。",{"type":917,"tag":918,"props":930,"children":931},{},[932],{"type":917,"tag":933,"props":934,"children":937},"img",{"alt":935,"src":936},"alt text","/image/zh_hans/getting-started/15.event/3.logic/image.png",[],{"type":917,"tag":939,"props":940,"children":942},"h2",{"id":941},"相关指令教程",[943],{"type":922,"value":941},{"type":917,"tag":945,"props":946,"children":948},"commands-item",{"type-name":947},"logic",[],{"title":911,"searchDepth":950,"depth":950,"links":951},2,[952],{"id":941,"depth":950,"text":941},"markdown","content:zh_hans:getting-started:15.event:3.logic.md","content","zh_hans/getting-started/15.event/3.logic.md","zh_hans/getting-started/15.event/3.logic","md",[960,962],{"_path":711,"title":710,"description":961},"变量是一种记录工具，通过变量可以记录、使用记录的值",{"_path":717,"title":716,"description":963},"用户可以自定义追加事件指令，可视化制作事件指令的编辑器，以及使用脚本编写相关的逻辑。",[965,973,1017,1045,1068,1462,1489,1528,1569,1658],{"_path":966,"_dir":947,"_draft":910,"_partial":967,"_locale":911,"title":266,"_id":968,"_type":969,"_source":955,"_file":970,"_stem":971,"_extension":972},"/zh_hans/commands/logic/_dir",true,"content:zh_hans:commands:logic:_dir.yml","yaml","zh_hans/commands/logic/_dir.yml","zh_hans/commands/logic/_dir","yml",{"_path":271,"_dir":947,"_draft":910,"_partial":910,"_locale":911,"title":270,"description":974,"applicationScope":975,"body":984,"_type":953,"_id":1014,"_source":955,"_file":1015,"_stem":1016,"_extension":958},"当执行循环后想停止，即可使用中断循环停止循环的执行",[976,977,978,979,980,981,982,983],199,3,