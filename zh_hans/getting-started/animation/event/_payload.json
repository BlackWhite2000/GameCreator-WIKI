:949,"props":988,"children":989},{},[990],{"type":922,"value":991},"控制NPC或玩家的移动/切换行走图/切换动作等等演出都可以通过设置对象行为指令来进行操作。",{"type":917,"tag":949,"props":993,"children":994},{},[995],{"type":922,"value":996},"比如就可以设置NPC走一段路。",{"type":917,"tag":949,"props":998,"children":999},{},[1000],{"type":922,"value":1001},"设置过程中是有一个预览窗口的，所以设置起来也是非常方便。",{"type":917,"tag":949,"props":1003,"children":1004},{},[1005],{"type":917,"tag":1006,"props":1007,"children":1010},"img",{"alt":1008,"src":1009},"alt text","/image/zh_hans/commands/sceneobject/backtotitlepage/image.png",[],{"type":917,"tag":949,"props":1012,"children":1013},{},[1014],{"type":917,"tag":1006,"props":1015,"children":1017},{"alt":1008,"src":1016},"/image/zh_hans/commands/sceneobject/backtotitlepage/image-1.png",[],{"type":917,"tag":918,"props":1019,"children":1020},{"id":114},[1021],{"type":922,"value":114},{"type":917,"tag":949,"props":1023,"children":1024},{},[1025],{"type":917,"tag":1006,"props":1026,"children":1028},{"alt":1008,"src":1027},"/image/zh_hans/commands/sceneobject/backtotitlepage/1.gif",[],{"title":911,"searchDepth":955,"depth":955,"links":1030},[1031,1032],{"id":984,"depth":955,"text":984},{"id":114,"depth":955,"text":114},"content:zh_hans:commands:sceneobject:setobjectbehavior.md","zh_hans/commands/sceneobject/setobjectbehavior.md","zh_hans/commands/sceneobject/setobjectbehavior",[1037],{"_path":308,"_dir":931,"_draft":910,"_partial":910,"_locale":911,"title":307,"description":1038,"applicationScope":1039,"body":1041,"_type":959,"_id":1316,"_source":961,"_file":1317,"_stem":1318,"_extension":964},"通过该指令可在游戏中显示剧情对话，只需要填写相关对话文本即可",[974,975,1040,976,977,978,979],182,{"type":914,"children":1042,"toc":1306},[1043,1048,1053,1058,1065,1070,1075,1089,1096,1101,1108,1114,1123,1128,1133,1140,1145,1150,1155,1162,1169,1174,1181,1188,1193,1198,1205,1210,1223,1228,1235,1240,1245,1252,1257,1262,1275,1282,1289,1294,1299],{"type":917,"tag":918,"props":1044,"children":1046},{"id":1045},"基本使用",[1047],{"type":922,"value":1045},{"type":917,"tag":949,"props":1049,"children":1050},{},[1051],{"type":922,"value":1052},"直接在内容区域输入对应文案即可，支持修改文本颜色、支持调用变量、函数等",{"type":917,"tag":949,"props":1054,"children":1055},{},[1056],{"type":922,"value":1057},"你可以像使用word文档一样轻松的使用它",{"type":917,"tag":949,"props":1059,"children":1060},{},[1061],{"type":917,"tag":1006,"props":1062,"children":1064},{"alt":1008,"src":1063},"/image/zh_hans/commands/news/showdialog/1.png",[],{"type":917,"tag":918,"props":1066,"children":1068},{"id":1067},"名称",[1069],{"type":922,"value":1067},{"type":917,"tag":949,"props":1071,"children":1072},{},[1073],{"type":922,"value":1074},"直接在输入框填写即可。支持修改名称颜色。",{"type":917,"tag":949,"props":1076,"children":1077},{},[1078,1080,1087],{"type":922,"value":1079},"也支持显示变量，如图中的",{"type":917,"tag":1081,"props":1082,"children":1084},"code",{"className":1083},[],[1085],{"type":922,"value":1086},"[@s1]",{"type":922,"value":1088},"表示编号为1的字符串变量。",{"type":917,"tag":949,"props":1090,"children":1091},{},[1092],{"type":917,"tag":1006,"props":1093,"children":1095},{"alt":1008,"src":1094},"/image/zh_hans/commands/news/showdialog/2.png",[],{"type":917,"tag":949,"props":1097,"children":1098},{},[1099],{"type":922,"value":1100},"关于变量如何调用，可通过插入了解。内容区调用变量的方法也同理。",{"type":917,"tag":949,"props":1102,"children":1103},{},[1104],{"type":917,"tag":1006,"props":1105,"children":1107},{"alt":1008,"src":1106},"/image/zh_hans/commands/news/showdialog/3.png",[],{"type":917,"tag":918,"props":1109,"children":1111},{"id":1110},"气泡对话漫画对话框模式",[1112],{"type":922,"value":1113},"气泡对话(漫画对话框模式)",{"type":917,"tag":1115,"props":1116,"children":1117},"blockquote",{},[1118],{"type":917,"tag":949,"props":1119,"children":1120},{},[1121],{"type":922,"value":1122},"拥有场景对象的模板拥有漫画对话框功能",{"type":917,"tag":949,"props":1124,"children":1125},{},[1126],{"type":922,"value":1127},"如果希望将对话框跟随在场景对象的某个位置上，则可以开启漫画对话框模式。",{"type":917,"tag":949,"props":1129,"children":1130},{},[1131],{"type":922,"value":1132},"指定希望跟随的场景对象即可。",{"type":917,"tag":949,"props":1134,"children":1135},{},[1136],{"type":917,"tag":1006,"props":1137,"children":1139},{"alt":1008,"src":1138},"/image/zh_hans/commands/news/showdialog/4.png",[],{"type":917,"tag":949,"props":1141,"children":1142},{},[1143],{"type":922,"value":1144},"但是使用漫画对话框的情况下，最好调整好样式。",{"type":917,"tag":949,"props":1146,"children":1147},{},[1148],{"type":922,"value":1149},"否则一整个对话框都显示在了场景对象上，这并不好看。",{"type":917,"tag":949,"props":1151,"children":1152},{},[1153],{"type":922,"value":1154},"如：",{"type":917,"tag":949,"props":1156,"children":1157},{},[1158],{"type":917,"tag":1006,"props":1159,"children":1161},{"alt":1008,"src":1160},"/image/zh_hans/commands/news/showdialog/5.png",[],{"type":917,"tag":949,"props":1163,"children":1164},{},[1165],{"type":917,"tag":1006,"props":1166,"children":1168},{"alt":1008,"src":1167},"/image/zh_hans/commands/news/showdialog/6.png",[],{"type":917,"tag":949,"props":1170,"children":1171},{},[1172],{"type":922,"value":1173},"模板默认预设里提供了漫画对话框模式下专用的样式，可供参考：",{"type":917,"tag":949,"props":1175,"children":1176},{},[1177],{"type":917,"tag":1006,"props":1178,"children":1180},{"alt":1008,"src":1179},"/image/zh_hans/commands/news/showdialog/7.png",[],{"type":917,"tag":949,"props":1182,"children":1183},{},[1184],{"type":917,"tag":1006,"props":1185,"children":1187},{"alt":1008,"src":1186},"/image/zh_hans/commands/news/showdialog/8.png",[],{"type":917,"tag":918,"props":1189,"children":1191},{"id":1190},"对话框样式",[1192],{"type":922,"value":1190},{"type":917,"tag":949,"props":1194,"children":1195},{},[1196],{"type":922,"value":1197},"对话最终的样式排版都取决于指定的对话样式。",{"type":917,"tag":949,"props":1199,"children":1200},{},[1201],{"type":917,"tag":1006,"props":1202,"children":1204},{"alt":1008,"src":1203},"/image/zh_hans/commands/news/showdialog/9.png",[],{"type":917,"tag":918,"props":1206,"children":1208},{"id":1207},"自定义对话框样式",[1209],{"type":922,"value":1207},{"type":917,"tag":949,"props":1211,"children":1212},{},[1213,1215,1221],{"type":922,"value":1214},"如果想要自定义对话框样式，可通过 ",{"type":917,"tag":1081,"props":1216,"children":1218},{"className":1217},[],[1219],{"type":922,"value":1220},"数据库(快捷键F10) -> 对话框样式",{"type":922,"value":1222}," 进行增改。",{"type":917,"tag":949,"props":1224,"children":1225},{},[1226],{"type":922,"value":1227},"直接选择对应组件然后替换素材、修改位置即可。步骤全程可视化，所以请大胆尝试。",{"type":917,"tag":949,"props":1229,"children":1230},{},[1231],{"type":917,"tag":1006,"props":1232,"children":1234},{"alt":1008,"src":1233},"/image/zh_hans/commands/news/showdialog/10.png",[],{"type":917,"tag":918,"props":1236,"children":1238},{"id":1237},"预览漫画模式",[1239],{"type":922,"value":1237},{"type":917,"tag":949,"props":1241,"children":1242},{},[1243],{"type":922,"value":1244},"开启预览漫画模式可以获取行走图来当参考目标。",{"type":917,"tag":949,"props":1246,"children":1247},{},[1248],{"type":917,"tag":1006,"props":1249,"children":1251},{"alt":1008,"src":1250},"/image/zh_hans/commands/news/showdialog/11.png",[],{"type":917,"tag":918,"props":1253,"children":1255},{"id":1254},"对话与选项一起出现",[1256],{"type":922,"value":1254},{"type":917,"tag":949,"props":1258,"children":1259},{},[1260],{"type":922,"value":1261},"默认情况下，只有执行完显示对话指令后才会执行后续指令，这种情况下没办法让对话与选项同时出现。",{"type":917,"tag":949,"props":1263,"children":1264},{},[1265,1267,1273],{"type":922,"value":1266},"而如果希望同时出现也很简单，只需要使用文字效果 ",{"type":917,"tag":1081,"props":1268,"children":1270},{"className":1269},[],[1271],{"type":922,"value":1272},"跳过本次对话",{"type":922,"value":1274}," 即可",{"type":917,"tag":949,"props":1276,"children":1277},{},[1278],{"type":917,"tag":1006,"props":1279,"children":1281},{"alt":1008,"src":1280},"/image/zh_hans/commands/news/showdialog/12.png",[],{"type":917,"tag":949,"props":1283,"children":1284},{},[1285],{"type":917,"tag":1006,"props":1286,"children":1288},{"alt":1008,"src":1287},"/image/zh_hans/commands/news/showdialog/13.png",[],{"type":917,"tag":918,"props":1290,"children":1292},{"id":1291},"预览对话",[1293],{"type":922,"value":1291},{"type":917,"tag":949,"props":1295,"children":1296},{},[1297],{"type":922,"value":1298},"开启预览对话可以直接在指令界面中预览游戏的效果。",{"type":917,"tag":949,"props":1300,"children":1301},{},[1302],{"type":917,"tag":1006,"props":1303,"children":1305},{"alt":1008,"src":1304},"/image/zh_hans/commands/news/showdialog/14.png",[],{"title":911,"searchDepth":955,"depth":955,"links":1307},[1308,1309,1310,1311,1312,1313,1314,1315],{"id":1045,"depth":955,"text":1045},{"id":1067,"depth":955,"text":1067},{"id":1110,"depth":955,"text":1113},{"id":1190,"depth":955,"text":1190},{"id":1207,"depth":955,"text":1207},{"id":1237,"depth":955,"text":1237},{"id":1254,"depth":955,"text":1254},{"id":1291,"depth":955,"text":1291},"content:zh_hans:commands:news:showdialog.md","zh_hans/commands/news/showdialog.md","zh_hans/commands/news/showdialog",[1320],{"_path":215,"_dir":936,"_draft":910,"_partial":910,"_locale":911,"title":214,"description":1321,"applicationScope":1322,"body":1323,"_type":959,"_id":1420,"_source":961,"_file":1421,"_stem":1422,"_extension":964},"通过该指令可在图像层上显示指定动画",[974,975,1040,976,977,978,979],{"type":914,"children":1324,"toc":1414},[1325,1329,1334,1341,1346,1351,1356,1363,1370,1375,1380,1385,1390,1397,1402,1407],{"type":917,"tag":918,"props":1326,"children":1327},{"id":984},[1328],{"type":922,"value":984},{"type":917,"tag":949,"props":1330,"children":1331},{},[1332],{"type":922,"value":1333},"通过指定动画即可将动画显示在场景地图上。",{"type":917,"tag":949,"props":1335,"children":1336},{},[1337],{"type":917,"tag":1006,"props":1338,"children":1340},{"alt":1008,"src":1339},"/image/zh_hans/commands/images/showanimation/image.png",[],{"type":917,"tag":918,"props":1342,"children":1344},{"id":1343},"开启可视化预览",[1345],{"type":922,"value":1343},{"type":917,"tag":949,"props":1347,"children":1348},{},[1349],{"type":922,"value":1350},"推荐开启预览事件页模式，能够更加方便的预览游戏效果。",{"type":917,"tag":949,"props":1352,"children":1353},{},[1354],{"type":922,"value":1355},"点击事件页上的这个按钮可以开启事件预览模式，这样就可以可视化预览游戏中的效果。",{"type":917,"tag":949,"props":1357,"children":1358},{},[1359],{"type":917,"tag":1006,"props":1360,"children":1362},{"alt":1008,"src":1361},"/image/zh_hans/commands/images/showanimation/image-1.png",[],{"type":917,"tag":949,"props":1364,"children":1365},{},[1366],{"type":917,"tag":1006,"props":1367,"children":1369},{"alt":1008,"src":1368},"/image/zh_hans/commands/images/showanimation/image-2.png",[],{"type":917,"tag":918,"props":1371,"children":1373},{"id":1372},"编号",[1374],{"type":922,"value":1372},{"type":917,"tag":949,"props":1376,"children":1377},{},[1378],{"type":922,"value":1379},"图像类型的指令都拥有编号，编号的作用类似变量编号一样。",{"type":917,"tag":949,"props":1381,"children":1382},{},[1383],{"type":922,"value":1384},"编号也涉及到了图像之间的层级关系。",{"type":917,"tag":949,"props":1386,"children":1387},{},[1388],{"type":922,"value":1389},"如下图中，显示动画编号是1，显示图片编号是2。所以显示图片层级比显示动画高。",{"type":917,"tag":949,"props":1391,"children":1392},{},[1393],{"type":917,"tag":1006,"props":1394,"children":1396},{"alt":1008,"src":1395},"/image/zh_hans/commands/images/showanimation/image-3.png",[],{"type":917,"tag":918,"props":1398,"children":1400},{"id":1399},"高级设定",[1401],{"type":922,"value":1399},{"type":917,"tag":949,"props":1403,"children":1404},{},[1405],{"type":922,"value":1406},"开启高级设定，可以将指定源变为指定变量。",{"type":917,"tag":949,"props":1408,"children":1409},{},[1410],{"type":917,"tag":1006,"props":1411,"children":1413},{"alt":1008,"src":1412},"/image/zh_hans/commands/images/showanimation/image-4.png",[],{"title":911,"searchDepth":955,"depth":955,"links":1415},[1416,1417,1418,1419],{"id":984,"depth":955,"text":984},{"id":1343,"depth":955,"text":1343},{"id":1372,"depth":955,"text":1372},{"id":1399,"depth":955,"text":1399},"content:zh_hans:commands:images:showanimation.md","zh_hans/commands/images/showanimation.md","zh_hans/commands/images/showanimation",1722856404384]