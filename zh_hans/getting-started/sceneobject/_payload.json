914,"_type":1410,"_id":1411,"_source":1412,"_file":1413,"_stem":1414,"_extension":1415},{"_path":910,"title":378},"/zh_hans/getting-started/sceneobject/_dir",false,"","场景对象是指放置在场景上的对象，每个场景对象拥有唯一的场景对象原型",{"type":915,"children":916,"toc":1398},"root",[917,924,929,934,976,982,987,997,1006,1015,1020,1025,1030,1037,1042,1047,1052,1062,1069,1074,1079,1084,1089,1094,1101,1108,1116,1121,1126,1131,1136,1144,1149,1154,1161,1167,1189,1194,1199,1203,1216,1296,1303,1310,1314,1319,1324,1331,1337,1358,1363,1368,1381,1386,1391],{"type":918,"tag":919,"props":920,"children":921},"element","p",{},[922],{"type":923,"value":913},"text",{"type":918,"tag":919,"props":925,"children":926},{},[927],{"type":923,"value":928},"场景对象作为一个显示容器，可能包含行走图、挂载的界面（比如血条、名字等）、挂载的动画",{"type":918,"tag":919,"props":930,"children":931},{},[932],{"type":923,"value":933},"场景对象可能包含若干个场景对象模块。",{"type":918,"tag":935,"props":936,"children":939},"div",{"className":937},[938],"flex",[940,954,965],{"type":918,"tag":935,"props":941,"children":944},{"className":942},[943],"w-[120px]",[945],{"type":918,"tag":919,"props":946,"children":947},{},[948],{"type":918,"tag":949,"props":950,"children":953},"img",{"alt":951,"src":952},"alt text","/image/zh_hans/getting-started/8.sceneobject/1.index/image.png",[],{"type":918,"tag":935,"props":955,"children":957},{"className":956},[943],[958],{"type":918,"tag":919,"props":959,"children":960},{},[961],{"type":918,"tag":949,"props":962,"children":964},{"alt":951,"src":963},"/image/zh_hans/getting-started/8.sceneobject/1.index/image-3.png",[],{"type":918,"tag":935,"props":966,"children":968},{"className":967},[943],[969],{"type":918,"tag":919,"props":970,"children":971},{},[972],{"type":918,"tag":949,"props":973,"children":975},{"alt":951,"src":974},"/image/zh_hans/getting-started/8.sceneobject/1.index/image-2.png",[],{"type":918,"tag":977,"props":978,"children":980},"h2",{"id":979},"部分游戏效果示例演示",[981],{"type":923,"value":979},{"type":918,"tag":919,"props":983,"children":984},{},[985],{"type":923,"value":986},"点击下方文字可弹出效果展示：",{"type":918,"tag":988,"props":989,"children":991},"game-box",{"src":990},"https://material.gamecreator.com.cn/releaseProject/1_8efa6a936a26aa77842be8944404fa95/5/index.html?3",[992],{"type":918,"tag":919,"props":993,"children":994},{},[995],{"type":923,"value":996},"【四方向行走图】#在线预览",{"type":918,"tag":988,"props":998,"children":1000},{"src":999},"https://material.gamecreator.com.cn/releaseProject/1_8efa6a936a26aa77842be8944404fa95/5/index.html?16",[1001],{"type":918,"tag":919,"props":1002,"children":1003},{},[1004],{"type":923,"value":1005},"【八方向行走图】#在线预览",{"type":918,"tag":988,"props":1007,"children":1009},{"src":1008},"https://material.gamecreator.com.cn/releaseProject/1_8efa6a936a26aa77842be8944404fa95/5/index.html?11",[1010],{"type":918,"tag":919,"props":1011,"children":1012},{},[1013],{"type":923,"value":1014},"【一方向行走图】#在线预览",{"type":918,"tag":977,"props":1016,"children":1018},{"id":1017},"关于基础属性",[1019],{"type":923,"value":1017},{"type":918,"tag":919,"props":1021,"children":1022},{},[1023],{"type":923,"value":1024},"场景对象一般具备坐标、显示层级等基础属性，而带有行走图的显示对象则具备针对行走图的体型、色相、播放频率等基础属性。",{"type":918,"tag":919,"props":1026,"children":1027},{},[1028],{"type":923,"value":1029},"此外选中场景对象后头顶上有一个辅助工具栏，可以设置名称、快速更换面向、动作及行走图。",{"type":918,"tag":919,"props":1031,"children":1032},{},[1033],{"type":918,"tag":949,"props":1034,"children":1036},{"alt":951,"src":1035},"/image/zh_hans/getting-started/8.sceneobject/1.index/image-4.png",[],{"type":918,"tag":977,"props":1038,"children":1040},{"id":1039},"关于触发器",[1041],{"type":923,"value":1039},{"type":918,"tag":919,"props":1043,"children":1044},{},[1045],{"type":923,"value":1046},"支持绑定自定义的触发器，比如点击对象的事件、碰触对象的事件等，自定义一个触发类别名称后在脚本中实现触发即可。",{"type":918,"tag":919,"props":1048,"children":1049},{},[1050],{"type":923,"value":1051},"满足执行条件的话多种事件是可以同时执行的。",{"type":918,"tag":1053,"props":1054,"children":1055},"ul",{},[1056],{"type":918,"tag":1057,"props":1058,"children":1059},"li",{},[1060],{"type":923,"value":1061},"比如《苍之羽》模板中每个对象都有：“点击事件”、“碰触事件”、“并行事件”等",{"type":918,"tag":919,"props":1063,"children":1064},{},[1065],{"type":918,"tag":949,"props":1066,"children":1068},{"alt":951,"src":1067},"/image/zh_hans/getting-started/8.sceneobject/1.index/image-5.png",[],{"type":918,"tag":977,"props":1070,"children":1072},{"id":1071},"关于出现条件和状态页",[1073],{"type":923,"value":1071},{"type":918,"tag":919,"props":1075,"children":1076},{},[1077],{"type":923,"value":1078},"状态页搭配出现条件使用，当满足了该状态页的出现条件时，则切换到该状态页上（顺序由下至上）。",{"type":918,"tag":919,"props":1080,"children":1081},{},[1082],{"type":923,"value":1083},"同一个场景对象的可以预设多个状态页，即拥有多个不同的属性和事件，但是当前只会显示一种状态页。",{"type":918,"tag":919,"props":1085,"children":1086},{},[1087],{"type":923,"value":1088},"一个对象可以根据不同的条件呈现出不同的状态是游戏制作内常用的一种手段。",{"type":918,"tag":919,"props":1090,"children":1091},{},[1092],{"type":923,"value":1093},"比如同一个场景对象，由于条件不同出现的状态即不同：",{"type":918,"tag":919,"props":1095,"children":1096},{},[1097],{"type":918,"tag":949,"props":1098,"children":1100},{"alt":951,"src":1099},"/image/zh_hans/getting-started/8.sceneobject/1.index/image-6.png",[],{"type":918,"tag":919,"props":1102,"children":1103},{},[1104],{"type":918,"tag":949,"props":1105,"children":1107},{"alt":951,"src":1106},"/image/zh_hans/getting-started/8.sceneobject/1.index/image-7.png",[],{"type":918,"tag":1053,"props":1109,"children":1110},{},[1111],{"type":918,"tag":1057,"props":1112,"children":1113},{},[1114],{"type":923,"value":1115},"这样可以充分利用一个场景对象在不同的场合下呈现不同的状态，如在满足某些剧情后原本存在的NPC就消失了，或者变成新的NPC了。",{"type":918,"tag":977,"props":1117,"children":1119},{"id":1118},"关于场景对象行为",[1120],{"type":923,"value":1118},{"type":918,"tag":919,"props":1122,"children":1123},{},[1124],{"type":923,"value":1125},"GC支持了自定义设定场景对象的行为，通常情况下模板都会预设好相关的对象行为让用户可以通过行为编辑器来编辑对象的行为。",{"type":918,"tag":919,"props":1127,"children":1128},{},[1129],{"type":923,"value":1130},"作者或模板制作者追加的自定义对象行为也可以实时预览到播放效果。",{"type":918,"tag":919,"props":1132,"children":1133},{},[1134],{"type":923,"value":1135},"对象每次被添加一组行为后都会加入到队列中，该队列是后加先上的特性，即后加入队列反而优先执行，执行完毕才执行前面队列的行为组：",{"type":918,"tag":1053,"props":1137,"children":1138},{},[1139],{"type":918,"tag":1057,"props":1140,"children":1141},{},[1142],{"type":923,"value":1143},"比如某场景对象的默认行为是：ABC，当它执行完A时，再给他再加入DEF的行为组，那么它的实际顺序是A-D-E-F-B-C。",{"type":918,"tag":919,"props":1145,"children":1146},{},[1147],{"type":923,"value":1148},"比如RPG游戏中行为可能包含移动、面向、跳跃等等。",{"type":918,"tag":919,"props":1150,"children":1151},{},[1152],{"type":923,"value":1153},"允许作者在对象的默认行为中进行编辑或在事件中指定某个对象执行哪些行为，同时支持实时预览：",{"type":918,"tag":919,"props":1155,"children":1156},{},[1157],{"type":918,"tag":949,"props":1158,"children":1160},{"alt":951,"src":1159},"/image/zh_hans/getting-started/8.sceneobject/1.index/image-8.png",[],{"type":918,"tag":977,"props":1162,"children":1164},{"id":1163},"高级特性场景对象原型",[1165],{"type":923,"value":1166},"高级特性：场景对象原型",{"type":918,"tag":919,"props":1168,"children":1169},{},[1170,1172,1179,1181,1187],{"type":923,"value":1171},"场景对象原型是预先定义的一类对象，由",{"type":918,"tag":1173,"props":1174,"children":1176},"code",{"className":1175},[],[1177],{"type":923,"value":1178},"公共模块",{"type":923,"value":1180},"以及",{"type":918,"tag":1173,"props":1182,"children":1184},{"className":1183},[],[1185],{"type":923,"value":1186},"预安装的场景对象模块",{"type":923,"value":1188},"组成。",{"type":918,"tag":919,"props":1190,"children":1191},{},[1192],{"type":923,"value":1193},"你可以理解为不同的原型就是不同的物种或类别",{"type":918,"tag":919,"props":1195,"children":1196},{},[1197],{"type":923,"value":1198},"通常为高级开发人员编辑的项，普通创作者仅需了解即可。",{"type":918,"tag":977,"props":1200,"children":1201},{"id":1178},[1202],{"type":923,"value":1178},{"type":918,"tag":919,"props":1204,"children":1205},{},[1206,1208,1214],{"type":923,"value":1207},"公共模块是指所有类别的原型都拥有的共同特性，都拥有公共的特性，由： ",{"type":918,"tag":1173,"props":1209,"children":1211},{"className":1210},[],[1212],{"type":923,"value":1213},"属性、显示对象、绑定的脚本、编辑器预览",{"type":923,"value":1215},"组成",{"type":918,"tag":1217,"props":1218,"children":1219},"table",{},[1220,1239],{"type":918,"tag":1221,"props":1222,"children":1223},"thead",{},[1224],{"type":918,"tag":1225,"props":1226,"children":1227},"tr",{},[1228,1234],{"type":918,"tag":1229,"props":1230,"children":1231},"th",{},[1232],{"type":923,"value":1233},"特征",{"type":918,"tag":1229,"props":1235,"children":1236},{},[1237],{"type":923,"value":1238},"说明",{"type":918,"tag":1240,"props":1241,"children":1242},"tbody",{},[1243,1257,1270,1283],{"type":918,"tag":1225,"props":1244,"children":1245},{},[1246,1252],{"type":918,"tag":1247,"props":1248,"children":1249},"td",{},[1250],{"type":923,"value":1251},"属性",{"type":918,"tag":1247,"props":1253,"children":1254},{},[1255],{"type":923,"value":1256},"自定义的属性，如生命值（数值类型）",{"type":918,"tag":1225,"props":1258,"children":1259},{},[1260,1265],{"type":918,"tag":1247,"props":1261,"children":1262},{},[1263],{"type":923,"value":1264},"显示对象",{"type":918,"tag":1247,"props":1266,"children":1267},{},[1268],{"type":923,"value":1269},"挂载的显示对象，如行走图、动画、界面等",{"type":918,"tag":1225,"props":1271,"children":1272},{},[1273,1278],{"type":918,"tag":1247,"props":1274,"children":1275},{},[1276],{"type":923,"value":1277},"绑定的脚本",{"type":918,"tag":1247,"props":1279,"children":1280},{},[1281],{"type":923,"value":1282},"由高级开发人员操作：所有场景对象都是指定的脚本类的实例",{"type":918,"tag":1225,"props":1284,"children":1285},{},[1286,1291],{"type":918,"tag":1247,"props":1287,"children":1288},{},[1289],{"type":923,"value":1290},"编辑器预览",{"type":918,"tag":1247,"props":1292,"children":1293},{},[1294],{"type":923,"value":1295},"由高级开发人员操作：可用于编写在编辑器环境下实时预览的效果",{"type":918,"tag":919,"props":1297,"children":1298},{},[1299],{"type":918,"tag":949,"props":1300,"children":1302},{"alt":951,"src":1301},"/image/zh_hans/getting-started/8.sceneobject/1.index/image-9.png",[],{"type":918,"tag":919,"props":1304,"children":1305},{},[1306],{"type":918,"tag":949,"props":1307,"children":1309},{"alt":951,"src":1308},"/image/zh_hans/getting-started/8.sceneobject/1.index/image-10.png",[],{"type":918,"tag":977,"props":1311,"children":1312},{"id":553},[1313],{"type":923,"value":553},{"type":918,"tag":919,"props":1315,"children":1316},{},[1317],{"type":923,"value":1318},"场景对象模块属于可组装式的组件，当场景对象拥有某一个模块时，即拥有了该模块的特性。",{"type":918,"tag":919,"props":1320,"children":1321},{},[1322],{"type":923,"value":1323},"模块通常来自模板预置、插件商城或高级开发人员自制。",{"type":918,"tag":919,"props":1325,"children":1326},{},[1327],{"type":918,"tag":949,"props":1328,"children":1330},{"alt":951,"src":1329},"/image/zh_hans/getting-started/8.sceneobject/1.index/image-11.png",[],{"type":918,"tag":977,"props":1332,"children":1334},{"id":1333},"高级特性自定义显示对象",[1335],{"type":923,"value":1336},"高级特性：自定义显示对象",{"type":918,"tag":919,"props":1338,"children":1339},{},[1340,1342,1348,1350,1356],{"type":923,"value":1341},"场景对象可以使用一个行走图对象，以及若干个",{"type":918,"tag":1173,"props":1343,"children":1345},{"className":1344},[],[1346],{"type":923,"value":1347},"动画对象",{"type":923,"value":1349},"和",{"type":918,"tag":1173,"props":1351,"children":1353},{"className":1352},[],[1354],{"type":923,"value":1355},"界面对象",{"type":923,"value":1357},"，均可在原型中预设好即可。",{"type":918,"tag":919,"props":1359,"children":1360},{},[1361],{"type":923,"value":1362},"可以指定固定的动画、界面，也可以指定一类动画或界面，这样让作者可以在属性栏中对每个对象进行选择。",{"type":918,"tag":919,"props":1364,"children":1365},{},[1366],{"type":923,"value":1367},"至于你定义的这些显示对象有什么作用目前则需要在脚本中实现相关的功能。",{"type":918,"tag":1053,"props":1369,"children":1370},{},[1371,1376],{"type":918,"tag":1057,"props":1372,"children":1373},{},[1374],{"type":923,"value":1375},"比如场景对象拥有血条，与自定义属性-生命值有关系，根据当前生命值和最大生命值来决定当前血条界面的状态",{"type":918,"tag":1057,"props":1377,"children":1378},{},[1379],{"type":923,"value":1380},"通常情况下，模板会预先设定好这些东西，以便普通作者直接使用。而高级开发者则可以任意修改和增删。",{"type":918,"tag":919,"props":1382,"children":1383},{},[1384],{"type":923,"value":1385},"下图展示的对象原型具备一个自定义界面类别和一个自定义动画类别，然后摆放到场景上之后可以选择具体是哪个界面或哪个动画：",{"type":918,"tag":919,"props":1387,"children":1388},{},[1389],{"type":923,"value":1390},"虽然两个人都来自原型-动物，但也具备不同的行走图、VIP等级、挂载的装饰动画等等。",{"type":918,"tag":919,"props":1392,"children":1393},{},[1394],{"type":918,"tag":949,"props":1395,"children":1397},{"alt":951,"src":1396},"/image/zh_hans/getting-started/8.sceneobject/1.index/image-12.png",[],{"title":912,"searchDepth":1399,"depth":1399,"links":1400},2,[1401,1402,1403,1404,1405,1406,1407,1408,1409],{"id":979,"depth":1399,"text":979},{"id":1017,"depth":1399,"text":1017},{"id":1039,"depth":1399,"text":1039},{"id":1071,"depth":1399,"text":1071},{"id":1118,"depth":1399,"text":1118},{"id":1163,"depth":1399,"text":1166},{"id":1178,"depth":1399,"text":1178},{"id":553,"depth":1399,"text":553},{"id":1333,"depth":1399,"text":1336},"markdown","content:zh_hans:getting-started:8.sceneobject:1.index.md","content","zh_hans/getting-started/8.sceneobject/1.index.md","zh_hans/getting-started/8.sceneobject/1.index","md",[1417,1419],{"_path":529,"title":528,"description":1418},"场景相关代码示例",{"_path":536,"title":535,"description":1420},"场景对象原型是预先定义的一类对象，由公共模块以及预安装的场景对象模块组成。",1722856401070]