2},{},[1403],{"type":917,"tag":1004,"props":1404,"children":1406},{"alt":1006,"src":1405},"/image/zh_hans/commands/sceneobject/modifyobjectmodule/image-1.png",[],{"title":911,"searchDepth":939,"depth":939,"links":1408},[1409,1410,1411],{"id":1301,"depth":939,"text":1304},{"id":992,"depth":939,"text":992},{"id":1381,"depth":939,"text":1384},"content:zh_hans:commands:sceneobject:modifyobjectmodule.md","zh_hans/commands/sceneobject/modifyobjectmodule.md","zh_hans/commands/sceneobject/modifyobjectmodule",{"_path":401,"_dir":909,"_draft":910,"_partial":910,"_locale":911,"title":400,"description":1416,"applicationScope":1417,"body":1418,"_type":943,"_id":1449,"_source":945,"_file":1450,"_stem":1451,"_extension":948},"执行此指令时，会同步记录当前的对象行为移动路径",[966,967,968,969],{"type":914,"children":1419,"toc":1446},[1420,1424,1429,1434],{"type":917,"tag":918,"props":1421,"children":1422},{"id":992},[1423],{"type":922,"value":992},{"type":917,"tag":933,"props":1425,"children":1426},{},[1427],{"type":922,"value":1428},"类似停止移动，场景对象会停止移动",{"type":917,"tag":933,"props":1430,"children":1431},{},[1432],{"type":922,"value":1433},"但是会在执行的瞬间记录对象的移动路径",{"type":917,"tag":933,"props":1435,"children":1436},{},[1437,1439,1444],{"type":922,"value":1438},"以便配合 ",{"type":917,"tag":1220,"props":1440,"children":1442},{"href":1441},"./restoremovepath",[1443],{"type":922,"value":406},{"type":922,"value":1445},"，恢复场景对象的移动",{"title":911,"searchDepth":939,"depth":939,"links":1447},[1448],{"id":992,"depth":939,"text":992},"content:zh_hans:commands:sceneobject:recordmovingpath.md","zh_hans/commands/sceneobject/recordmovingpath.md","zh_hans/commands/sceneobject/recordmovingpath",{"_path":404,"_dir":909,"_draft":910,"_partial":910,"_locale":911,"title":403,"description":1453,"applicationScope":1454,"body":1455,"_type":943,"_id":1486,"_source":945,"_file":1487,"_stem":1488,"_extension":948},"通过此指令可移除掉场景上的对象，但是对象列表里依然存在该对象，仍然可以被获取到。",[966,967,968,969,970,971],{"type":914,"children":1456,"toc":1483},[1457,1461,1466,1471,1476],{"type":917,"tag":918,"props":1458,"children":1459},{"id":992},[1460],{"type":922,"value":992},{"type":917,"tag":933,"props":1462,"children":1463},{},[1464],{"type":922,"value":1465},"可以在游戏中移除指定的场景对象。",{"type":917,"tag":933,"props":1467,"children":1468},{},[1469],{"type":922,"value":1470},"但是移除并不是完全的删除该场景对象，依然可以通过其他方式去获取到场景对象的某些数据。",{"type":917,"tag":933,"props":1472,"children":1473},{},[1474],{"type":922,"value":1475},"所以称为暂时移除。",{"type":917,"tag":933,"props":1477,"children":1478},{},[1479],{"type":917,"tag":1004,"props":1480,"children":1482},{"alt":1006,"src":1481},"/image/zh_hans/commands/sceneobject/removeobject/image.png",[],{"title":911,"searchDepth":939,"depth":939,"links":1484},[1485],{"id":992,"depth":939,"text":992},"content:zh_hans:commands:sceneobject:removeobject.md","zh_hans/commands/sceneobject/removeobject.md","zh_hans/commands/sceneobject/removeobject",{"_path":407,"_dir":909,"_draft":910,"_partial":910,"_locale":911,"title":406,"description":1490,"applicationScope":1491,"body":1492,"_type":943,"_id":1518,"_source":945,"_file":1519,"_stem":1520,"_extension":948},"执行记录移动路径时的路径。",[966,967,968,969],{"type":914,"children":1493,"toc":1515},[1494,1498,1510],{"type":917,"tag":918,"props":1495,"children":1496},{"id":992},[1497],{"type":922,"value":992},{"type":917,"tag":933,"props":1499,"children":1500},{},[1501,1503,1508],{"type":922,"value":1502},"当执行了 ",{"type":917,"tag":1220,"props":1504,"children":1506},{"href":1505},"./recordmovingpath",[1507],{"type":922,"value":400},{"type":922,"value":1509}," 时，场景对象会停止移动",{"type":917,"tag":933,"props":1511,"children":1512},{},[1513],{"type":922,"value":1514},"通过此指令可以让停止移动的场景对象恢复移动",{"title":911,"searchDepth":939,"depth":939,"links":1516},[1517],{"id":992,"depth":939,"text":992},"content:zh_hans:commands:sceneobject:restoremovepath.md","zh_hans/commands/sceneobject/restoremovepath.md","zh_hans/commands/sceneobject/restoremovepath",{"_path":410,"_dir":909,"_draft":910,"_partial":910,"_locale":911,"title":409,"description":1522,"applicationScope":1523,"body":1524,"_type":943,"_id":1598,"_source":945,"_file":1599,"_stem":1600,"_extension":948},"可以通过此指令实现在游戏中修改场景对象的属性",[966,967,968,969,970,971],{"type":914,"children":1525,"toc":1594},[1526,1530,1535,1540,1550,1557,1575,1582,1587],{"type":917,"tag":918,"props":1527,"children":1528},{"id":992},[1529],{"type":922,"value":992},{"type":917,"tag":933,"props":1531,"children":1532},{},[1533],{"type":922,"value":1534},"指定对象，然后选择需要修改的属性即可。",{"type":917,"tag":918,"props":1536,"children":1538},{"id":1537},"示例",[1539],{"type":922,"value":1537},{"type":917,"tag":933,"props":1541,"children":1542},{},[1543,1545],{"type":922,"value":1544},"指定对象 ",{"type":917,"tag":1328,"props":1546,"children":1548},{"className":1547},[],[1549],{"type":922,"value":1333},{"type":917,"tag":933,"props":1551,"children":1552},{},[1553],{"type":917,"tag":1004,"props":1554,"children":1556},{"alt":1006,"src":1555},"/image/zh_hans/commands/sceneobject/sceneobjectattributes/image.png",[],{"type":917,"tag":933,"props":1558,"children":1559},{},[1560,1561,1567,1569],{"type":922,"value":1326},{"type":917,"tag":1328,"props":1562,"children":1564},{"className":1563},[],[1565],{"type":922,"value":1566},"穿透",{"type":922,"value":1568}," 设置为 ",{"type":917,"tag":1328,"props":1570,"children":1572},{"className":1571},[],[1573],{"type":922,"value":1574},"开启",{"type":917,"tag":933,"props":1576,"children":1577},{},[1578],{"type":917,"tag":1004,"props":1579,"children":1581},{"alt":1006,"src":1580},"/image/zh_hans/commands/sceneobject/sceneobjectattributes/image-1.png",[],{"type":917,"tag":933,"props":1583,"children":1584},{},[1585],{"type":922,"value":1586},"最终场景对象将会拥有穿透效果",{"type":917,"tag":933,"props":1588,"children":1589},{},[1590],{"type":917,"tag":1004,"props":1591,"children":1593},{"alt":1006,"src":1592},"/image/zh_hans/commands/sceneobject/sceneobjectattributes/image-2.png",[],{"title":911,"searchDepth":939,"depth":939,"links":1595},[1596,1597],{"id":992,"depth":939,"text":992},{"id":1537,"depth":939,"text":1537},"content:zh_hans:commands:sceneobject:sceneobjectattributes.md","zh_hans/commands/sceneobject/sceneobjectattributes.md","zh_hans/commands/sceneobject/sceneobjectattributes",{"_path":413,"_dir":909,"_draft":910,"_partial":910,"_locale":911,"title":412,"description":1602,"applicationScope":1603,"body":1604,"_type":943,"_id":1654,"_source":945,"_file":1655,"_stem":1656,"_extension":948},"常用指令，通常是为了控制场景对象的行为",[966,967,968,969,970,971],{"type":914,"children":1605,"toc":1650},[1606,1610,1615,1620,1625,1632,1639,1643],{"type":917,"tag":918,"props":1607,"children":1608},{"id":992},[1609],{"type":922,"value":992},{"type":917,"tag":933,"props":1611,"children":1612},{},[1613],{"type":922,"value":1614},"控制NPC或玩家的移动/切换行走图/切换动作等等演出都可以通过设置对象行为指令来进行操作。",{"type":917,"tag":933,"props":1616,"children":1617},{},[1618],{"type":922,"value":1619},"比如就可以设置NPC走一段路。",{"type":917,"tag":933,"props":1621,"children":1622},{},[1623],{"type":922,"value":1624},"设置过程中是有一个预览窗口的，所以设置起来也是非常方便。",{"type":917,"tag":933,"props":1626,"children":1627},{},[1628],{"type":917,"tag":1004,"props":1629,"children":1631},{"alt":1006,"src":1630},"/image/zh_hans/commands/sceneobject/backtotitlepage/image.png",[],{"type":917,"tag":933,"props":1633,"children":1634},{},[1635],{"type":917,"tag":1004,"props":1636,"children":1638},{"alt":1006,"src":1637},"/image/zh_hans/commands/sceneobject/backtotitlepage/image-1.png",[],{"type":917,"tag":918,"props":1640,"children":1641},{"id":114},[1642],{"type":922,"value":114},{"type":917,"tag":933,"props":1644,"children":1645},{},[1646],{"type":917,"tag":1004,"props":1647,"children":1649},{"alt":1006,"src":1648},"/image/zh_hans/commands/sceneobject/backtotitlepage/1.gif",[],{"title":911,"searchDepth":939,"depth":939,"links":1651},[1652,1653],{"id":992,"depth":939,"text":992},{"id":114,"depth":939,"text":114},"content:zh_hans:commands:sceneobject:setobjectbehavior.md","zh_hans/commands/sceneobject/setobjectbehavior.md","zh_hans/commands/sceneobject/setobjectbehavior",{"_path":416,"_dir":909,"_draft":910,"_partial":910,"_locale":911,"title":415,"description":1658,"applicationScope":1659,"body":1660,"_type":943,"_id":1701,"_source":945,"_file":1702,"_stem":1703,"_extension":948},"停止移动可以停止对象的一个移动行为",[966,967,968,969],{"type":914,"children":1661,"toc":1698},[1662,1666,1671,1676,1683,1693],{"type":917,"tag":918,"props":1663,"children":1664},{"id":992},[1665],{"type":922,"value":992},{"type":917,"tag":933,"props":1667,"children":1668},{},[1669],{"type":922,"value":1670},"停止移动执行一次只能停止一个移动行为，但是在绝大多数的情况下场景对象都是有多个行为存在的",{"type":917,"tag":933,"props":1672,"children":1673},{},[1674],{"type":922,"value":1675},"如下图，就是设置了多个移动行为的指令",{"type":917,"tag":933,"props":1677,"children":1678},{},[1679],{"type":917,"tag":1004,"props":1680,"children":1682},{"alt":1006,"src":1681},"/image/zh_hans/commands/sceneobject/stopmoving/image.png",[],{"type":917,"tag":933,"props":1684,"children":1685},{},[1686,1688],{"type":922,"value":1687},"如果你是希望消除多个行为，更推荐使用 ",{"type":917,"tag":1220,"props":1689,"children":1691},{"href":1690},"./clearobjectbehavior",[1692],{"type":922,"value":385},{"type":917,"tag":933,"props":1694,"children":1695},{},[1696],{"type":922,"value":1697},"如果你是希望停止(消除)一个移动行为，则可以使用停止移动指令",{"title":911,"searchDepth":939,"depth":939,"links":1699},[1700],{"id":992,"depth":939,"text":992},"content:zh_hans:commands:sceneobject:stopmoving.md","zh_hans/commands/sceneobject/stopmoving.md","zh_hans/commands/sceneobject/stopmoving",{"_path":419,"_dir":909,"_draft":910,"_partial":910,"_locale":911,"title":418,"description":1705,"applicationScope":1706,"body":1707,"_type":943,"_id":1728,"_source":945,"_file":1729,"_stem":1730,"_extension":948},"设置对象行为执行完毕后才会执行后续事件",[966,967,968,969,970,971],{"type":914,"children":1708,"toc":1725},[1709,1713,1718],{"type":917,"tag":918,"props":1710,"children":1711},{"id":992},[1712],{"type":922,"value":992},{"type":917,"tag":933,"props":1714,"children":1715},{},[1716],{"type":922,"value":1717},"添加等待行为结束后，只有设置对象行为完整的被执行完毕后才会继续执行后续事件。",{"type":917,"tag":933,"props":1719,"children":1720},{},[1721],{"type":917,"tag":1004,"props":1722,"children":1724},{"alt":1006,"src":1723},"/image/zh_hans/commands/sceneobject/waitbehaviorover/image.png",[],{"title":911,"searchDepth":939,"depth":939,"links":1726},[1727],{"id":992,"depth":939,"text":992},"content:zh_hans:commands:sceneobject:waitbehaviorover.md","zh_hans/commands/sceneobject/waitbehaviorover.md","zh_hans/commands/sceneobject/waitbehaviorover",1722856402330]