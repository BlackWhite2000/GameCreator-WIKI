:911,"title":525,"description":912,"body":913,"_type":943,"_id":944,"_source":945,"_file":946,"_stem":947,"_extension":948},"sceneobject",false,"","能够控制场景对象的指令",{"type":914,"children":915,"toc":938},"root",[916,923,927,932],{"type":917,"tag":918,"props":919,"children":920},"element","h2",{"id":525},[921],{"type":922,"value":525},"text",{"type":917,"tag":924,"props":925,"children":926},"commands-type-item",{"type-name":909},[],{"type":917,"tag":918,"props":928,"children":930},{"id":929},"自定义事件指令",[931],{"type":922,"value":929},{"type":917,"tag":933,"props":934,"children":935},"p",{},[936],{"type":922,"value":937},"由于GameCreator允许用户自制模板修改编辑器，可能会有各种指令或者属性中涉及了场景，具体功能由具体的项目而定",{"title":911,"searchDepth":939,"depth":939,"links":940},2,[941,942],{"id":525,"depth":939,"text":525},{"id":929,"depth":939,"text":929},"markdown","content:zh_hans:getting-started:8.sceneobject:9.event.md","content","zh_hans/getting-started/8.sceneobject/9.event.md","zh_hans/getting-started/8.sceneobject/9.event","md",[950,952],{"_path":554,"title":553,"description":951},"场景对象模块属于可组装式的组件，当场景对象拥有某一个模块时，即拥有了该模块的特性",{"_path":558,"title":528,"description":953},"场景对象的代码示例",[955,963,1016,1043,1205,1238,1294,1415,1452,1489,1521,1601,1657,1704],{"_path":956,"_dir":909,"_draft":910,"_partial":957,"_locale":911,"title":378,"_id":958,"_type":959,"_source":945,"_file":960,"_stem":961,"_extension":962},"/zh_hans/commands/sceneobject/_dir",true,"content:zh_hans:commands:sceneobject:_dir.yml","yaml","zh_hans/commands/sceneobject/_dir.yml","zh_hans/commands/sceneobject/_dir","yml",{"_path":383,"_dir":909,"_draft":910,"_partial":910,"_locale":911,"title":382,"description":964,"applicationScope":965,"body":972,"_type":943,"_id":1013,"_source":945,"_file":1014,"_stem":1015,"_extension":948},"可以在游戏中增加减少对象的模块",[966,967,968,969,970,971],199,3,193,1,302,325,{"type":914,"children":973,"toc":1009},[974,980,985,990,995,1000],{"type":917,"tag":918,"props":975,"children":977},{"id":976},"与修改场景对象模块属性区别",[978],{"type":922,"value":979},"与修改场景对象模块属性区别?",{"type":917,"tag":933,"props":981,"children":982},{},[983],{"type":922,"value":984},"增减场景对象的模块是新增、移除场景对象模块。",{"type":917,"tag":933,"props":986,"children":987},{},[988],{"type":922,"value":989},"而想修改，就必须保证场景对象模块存在",{"type":917,"tag":918,"props":991,"children":993},{"id":992},"使用",[994],{"type":922,"value":992},{"type":917,"tag":933,"props":996,"children":997},{},[998],{"type":922,"value":999},"通过指定场景对象，然后选择增加或移除指定的模块即可。",{"type":917,"tag":933,"props":1001,"children":1002},{},[1003],{"type":917,"tag":1004,"props":1005,"children":1008},"img",{"alt":1006,"src":1007},"alt text","/image/zh_hans/commands/sceneobject/changeobjectmodule/image.png",[],{"title":911,"searchDepth":939,"depth":939,"links":1010},[1011,1012],{"id":976,"depth":939,"text":979},{"id":992,"depth":939,"text":992},"content:zh_hans:commands:sceneobject:changeobjectmodule.md","zh_hans/commands/sceneobject/changeobjectmodule.md","zh_hans/commands/sceneobject/changeobjectmodule",{"_path":386,"_dir":909,"_draft":910,"_partial":910,"_locale":911,"title":385,"description":1017,"applicationScope":1018,"body":1019,"_type":943,"_id":1040,"_source":945,"_file":1041,"_stem":1042,"_extension":948},"可以将当前场景对象的行为清除掉",[966,967,968,969,970,971],{"type":914,"children":1020,"toc":1037},[1021,1025,1030],{"type":917,"tag":918,"props":1022,"children":1023},{"id":992},[1024],{"type":922,"value":992},{"type":917,"tag":933,"props":1026,"children":1027},{},[1028],{"type":922,"value":1029},"直接使用即可，使用后指定的场景对象将立即停止当前执行的对象行为。",{"type":917,"tag":933,"props":1031,"children":1032},{},[1033],{"type":917,"tag":1004,"props":1034,"children":1036},{"alt":1006,"src":1035},"/image/zh_hans/commands/sceneobject/clearobjectbehavior/image.png",[],{"title":911,"searchDepth":939,"depth":939,"links":1038},[1039],{"id":992,"depth":939,"text":992},"content:zh_hans:commands:sceneobject:clearobjectbehavior.md","zh_hans/commands/sceneobject/clearobjectbehavior.md","zh_hans/commands/sceneobject/clearobjectbehavior",{"_path":389,"_dir":909,"_draft":910,"_partial":910,"_locale":911,"title":388,"description":1044,"applicationScope":1045,"body":1046,"_type":943,"_id":1202,"_source":945,"_file":1203,"_stem":1204,"_extension":948},"可以将一个场景对象克隆多份生成在场景上",[966,967,968,969,970,971],{"type":914,"children":1047,"toc":1191},[1048,1052,1057,1062,1068,1073,1078,1085,1090,1095,1102,1107,1112,1117,1124,1129,1136,1140,1147,1152,1157,1162,1167,1174,1179,1184],{"type":917,"tag":918,"props":1049,"children":1050},{"id":992},[1051],{"type":922,"value":992},{"type":917,"tag":933,"props":1053,"children":1054},{},[1055],{"type":922,"value":1056},"克隆对象可以在场景地图上将一个场景对象克隆多份然后生成出来。",{"type":917,"tag":933,"props":1058,"children":1059},{},[1060],{"type":922,"value":1061},"克隆对象非常的好用，十分推荐各位多了解。通过克隆对象可以实现比如种田/砍树等等有意思的系统。",{"type":917,"tag":1063,"props":1064,"children":1066},"h3",{"id":1065},"设定克隆地图以及克隆的对象",[1067],{"type":922,"value":1065},{"type":917,"tag":933,"props":1069,"children":1070},{},[1071],{"type":922,"value":1072},"首先比较建议的方式是创建一个克隆专属地图。",{"type":917,"tag":933,"props":1074,"children":1075},{},[1076],{"type":922,"value":1077},"这样的话可以方便管理被克隆的场景对象，有点类似游戏中的作者房间。",{"type":917,"tag":933,"props":1079,"children":1080},{},[1081],{"type":917,"tag":1004,"props":1082,"children":1084},{"alt":1006,"src":1083},"/image/zh_hans/commands/sceneobject/cloneobject/image.png",[],{"type":917,"tag":933,"props":1086,"children":1087},{},[1088],{"type":922,"value":1089},"然后在这个地图上设定希望克隆的场景对象。",{"type":917,"tag":933,"props":1091,"children":1092},{},[1093],{"type":922,"value":1094},"克隆对象会把克隆的场景对象携带的属性/事件等等设定都克隆上，比如下图中场景对象的显示对象指令也会一起被克隆。",{"type":917,"tag":933,"props":1096,"children":1097},{},[1098],{"type":917,"tag":1004,"props":1099,"children":1101},{"alt":1006,"src":1100},"/image/zh_hans/commands/sceneobject/cloneobject/image-1.png",[],{"type":917,"tag":1063,"props":1103,"children":1105},{"id":1104},"设定克隆参数",[1106],{"type":922,"value":1104},{"type":917,"tag":933,"props":1108,"children":1109},{},[1110],{"type":922,"value":1111},"首先选择刚才创建的克隆专属地图【1-克隆地图】。",{"type":917,"tag":933,"props":1113,"children":1114},{},[1115],{"type":922,"value":1116},"然后指定被克隆的场景对象编号。",{"type":917,"tag":933,"props":1118,"children":1119},{},[1120],{"type":917,"tag":1004,"props":1121,"children":1123},{"alt":1006,"src":1122},"/image/zh_hans/commands/sceneobject/cloneobject/image-2.png",[],{"type":917,"tag":933,"props":1125,"children":1126},{},[1127],{"type":922,"value":1128},"接下来设置场景对象克隆后的坐标即可。",{"type":917,"tag":933,"props":1130,"children":1131},{},[1132],{"type":917,"tag":1004,"props":1133,"children":1135},{"alt":1006,"src":1134},"/image/zh_hans/commands/sceneobject/cloneobject/image-3.png",[],{"type":917,"tag":918,"props":1137,"children":1138},{"id":114},[1139],{"type":922,"value":114},{"type":917,"tag":933,"props":1141,"children":1142},{},[1143],{"type":917,"tag":1004,"props":1144,"children":1146},{"alt":1006,"src":1145},"/image/zh_hans/commands/sceneobject/cloneobject/1.gif",[],{"type":917,"tag":918,"props":1148,"children":1150},{"id":1149},"其他参数",[1151],{"type":922,"value":1149},{"type":917,"tag":1063,"props":1153,"children":1155},{"id":1154},"存储生成后的对象编号",[1156],{"type":922,"value":1154},{"type":917,"tag":933,"props":1158,"children":1159},{},[1160],{"type":922,"value":1161},"克隆对象生成后，自然会拥有一个对象编号。",{"type":917,"tag":933,"props":1163,"children":1164},{},[1165],{"type":922,"value":1166},"如果想清楚知道克隆后的对象编号可以通过绑定变量来实现。",{"type":917,"tag":933,"props":1168,"children":1169},{},[1170],{"type":917,"tag":1004,"props":1171,"children":1173},{"alt":1006,"src":1172},"/image/zh_hans/commands/sceneobject/cloneobject/image-4.png",[],{"type":917,"tag":1063,"props":1175,"children":1177},{"id":1176},"生成对象后执行事件",[1178],{"type":922,"value":1176},{"type":917,"tag":933,"props":1180,"children":1181},{},[1182],{"type":922,"value":1183},"克隆对象生成后，如果希望还能执行事件可以在此处事件页上写事件。",{"type":917,"tag":933,"props":1185,"children":1186},{},[1187],{"type":917,"tag":1004,"props":1188,"children":1190},{"alt":1006,"src":1189},"/image/zh_hans/commands/sceneobject/cloneobject/image-5.png",[],{"title":911,"searchDepth":939,"depth":939,"links":1192},[1193,1197,1198],{"id":992,"depth":939,"text":992,"children":1194},[1195,1196],{"id":1065,"depth":967,"text":1065},{"id":1104,"depth":967,"text":1104},{"id":114,"depth":939,"text":114},{"id":1149,"depth":939,"text":1149,"children":1199},[1200,1201],{"id":1154,"depth":967,"text":1154},{"id":1176,"depth":967,"text":1176},"content:zh_hans:commands:sceneobject:cloneobject.md","zh_hans/commands/sceneobject/cloneobject.md","zh_hans/commands/sceneobject/cloneobject",{"_path":392,"_dir":909,"_draft":910,"_partial":910,"_locale":911,"title":391,"description":1206,"applicationScope":1207,"body":1208,"_type":943,"_id":1235,"_source":945,"_file":1236,"_stem":1237,"_extension":948},"可以移除克隆的场景对象",[966,967,968,969,970,971],{"type":914,"children":1209,"toc":1232},[1210,1214,1227],{"type":917,"tag":918,"props":1211,"children":1212},{"id":992},[1213],{"type":922,"value":992},{"type":917,"tag":933,"props":1215,"children":1216},{},[1217,1219,1225],{"type":922,"value":1218},"通过此指令可以把 ",{"type":917,"tag":1220,"props":1221,"children":1223},"a",{"href":1222},"./cloneobject",[1224],{"type":922,"value":388},{"type":922,"value":1226}," 克隆出来的场景对象给移除掉。",{"type":917,"tag":933,"props":1228,"children":1229},{},[1230],{"type":922,"value":1231},"请注意，该指令只对克隆后的对象有效果。",{"title":911,"searchDepth":939,"depth":939,"links":1233},[1234],{"id":992,"depth":939,"text":992},"content:zh_hans:commands:sceneobject:destroycloneobject.md","zh_hans/commands/sceneobject/destroycloneobject.md","zh_hans/commands/sceneobject/destroycloneobject",{"_path":395,"_dir":909,"_draft":910,"_partial":910,"_locale":911,"title":394,"description":1239,"applicationScope":1240,"body":1241,"_type":943,"_id":1291,"_source":945,"_file":1292,"_stem":1293,"_extension":948},"可以在游戏中更改行走图的部件",[966,967,968,969,970,971],{"type":914,"children":1242,"toc":1287},[1243,1247,1252,1257,1264,1269,1276,1280],{"type":917,"tag":918,"props":1244,"children":1245},{"id":992},[1246],{"type":92