partial":910,"_locale":911,"title":525,"description":912,"body":913,"_type":953,"_id":954,"_source":955,"_file":956,"_stem":957,"_extension":958},"dialog",false,"","与对话框样式相关的指令",{"type":914,"children":915,"toc":948},"root",[916,923,937,942],{"type":917,"tag":918,"props":919,"children":920},"element","h2",{"id":525},[921],{"type":922,"value":525},"text",{"type":917,"tag":924,"props":925,"children":926},"ul",{},[927,933],{"type":917,"tag":928,"props":929,"children":932},"commands-item",{"page-name":930,"type-name":931},"showdialog","news",[],{"type":917,"tag":928,"props":934,"children":936},{"page-name":935,"type-name":931},"showchoices",[],{"type":917,"tag":918,"props":938,"children":940},{"id":939},"自定义事件指令",[941],{"type":922,"value":939},{"type":917,"tag":943,"props":944,"children":945},"p",{},[946],{"type":922,"value":947},"由于GameCreator允许用户自制模板修改编辑器，可能会有各种指令或者属性中涉及了场景，具体功能由具体的项目而定",{"title":911,"searchDepth":949,"depth":949,"links":950},2,[951,952],{"id":525,"depth":949,"text":525},{"id":939,"depth":949,"text":939},"markdown","content:zh_hans:getting-started:12.dialog:4.event.md","content","zh_hans/getting-started/12.dialog/4.event.md","zh_hans/getting-started/12.dialog/4.event","md",[960,962],{"_path":621,"title":620,"description":961},"通过对话框样式编辑器可以直观的编辑各种游戏对话框",{"_path":625,"title":492,"description":963},"界面系统主要用于游戏中显示的各种界面",[965],{"_path":308,"_dir":931,"_draft":910,"_partial":910,"_locale":911,"title":307,"description":966,"applicationScope":967,"body":975,"_type":953,"_id":1252,"_source":955,"_file":1253,"_stem":1254,"_extension":958},"通过该指令可在游戏中显示剧情对话，只需要填写相关对话文本即可",[968,969,970,971,972,973,974],199,3,182,193,1,302,325,{"type":914,"children":976,"toc":1242},[977,982,987,992,1001,1006,1011,1025,1032,1037,1044,1050,1059,1064,1069,1076,1081,1086,1091,1098,1105,1110,1117,1124,1129,1134,1141,1146,1159,1164,1171,1176,1181,1188,1193,1198,1211,1218,1225,1230,1235],{"type":917,"tag":918,"props":978,"children":980},{"id":979},"基本使用",[981],{"type":922,"value":979},{"type":917,"tag":943,"props":983,"children":984},{},[985],{"type":922,"value":986},"直接在内容区域输入对应文案即可，支持修改文本颜色、支持调用变量、函数等",{"type":917,"tag":943,"props":988,"children":989},{},[990],{"type":922,"value":991},"你可以像使用word文档一样轻松的使用它",{"type":917,"tag":943,"props":993,"children":994},{},[995],{"type":917,"tag":996,"props":997,"children":1000},"img",{"alt":998,"src":999},"alt text","/image/zh_hans/commands/news/showdialog/1.png",[],{"type":917,"tag":918,"props":1002,"children":1004},{"id":1003},"名称",[1005],{"type":922,"value":1003},{"type":917,"tag":943,"props":1007,"children":1008},{},[1009],{"type":922,"value":1010},"直接在输入框填写即可。支持修改名称颜色。",{"type":917,"tag":943,"props":1012,"children":1013},{},[1014,1016,1023],{"type":922,"value":1015},"也支持显示变量，如图中的",{"type":917,"tag":1017,"props":1018,"children":1020},"code",{"className":1019},[],[1021],{"type":922,"value":1022},"[@s1]",{"type":922,"value":1024},"表示编号为1的字符串变量。",{"type":917,"tag":943,"props":1026,"children":1027},{},[1028],{"type":917,"tag":996,"props":1029,"children":1031},{"alt":998,"src":1030},"/image/zh_hans/commands/news/showdialog/2.png",[],{"type":917,"tag":943,"props":1033,"children":1034},{},[1035],{"type":922,"value":1036},"关于变量如何调用，可通过插入了解。内容区调用变量的方法也同理。",{"type":917,"tag":943,"props":1038,"children":1039},{},[1040],{"type":917,"tag":996,"props":1041,"children":1043},{"alt":998,"src":1042},"/image/zh_hans/commands/news/showdialog/3.png",[],{"type":917,"tag":918,"props":1045,"children":1047},{"id":1046},"气泡对话漫画对话框模式",[1048],{"type":922,"value":1049},"气泡对话(漫画对话框模式)",{"type":917,"tag":1051,"props":1052,"children":1053},"blockquote",{},[1054],{"type":917,"tag":943,"props":1055,"children":1056},{},[1057],{"type":922,"value":1058},"拥有场景对象的模板拥有漫画对话框功能",{"type":917,"tag":943,"props":1060,"children":1061},{},[1062],{"type":922,"value":1063},"如果希望将对话框跟随在场景对象的某个位置上，则可以开启漫画对话框模式。",{"type":917,"tag":943,"props":1065,"children":1066},{},[1067],{"type":922,"value":1068},"指定希望跟随的场景对象即可。",{"type":917,"tag":943,"props":1070,"childr